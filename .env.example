# Database
# Neon pooled connection string. Use a host with "-pooler" for app/runtime.
DATABASE_URL="postgresql://user:password@ep-example-pooler.region.aws.neon.tech/neondb?sslmode=require&connect_timeout=15"
# Neon direct connection string. Use the same host without "-pooler" for Prisma schema commands.
DIRECT_URL="postgresql://user:password@ep-example.region.aws.neon.tech/neondb?sslmode=require&connect_timeout=15"

# Auth - JWT Secret (generate with: openssl rand -base64 32)
JWT_SECRET="your-super-secret-jwt-key-change-this-in-production"

# App
NEXTAUTH_URL="http://localhost:3000"
NODE_ENV="development"

# Upload
# Arquivos enviados sao gravados no banco para funcionar em ambiente serverless.
MAX_FILE_SIZE=10485760
