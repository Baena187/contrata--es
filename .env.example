# Database
# Neon pooled connection string. Use a host com "-pooler" para o app em runtime.
DATABASE_URL="postgresql://user:password@ep-example-pooler.region.aws.neon.tech/neondb?sslmode=require&connect_timeout=15"
# Neon direct connection string. Use sem "-pooler" para comandos Prisma (migrate, push).
DIRECT_URL="postgresql://user:password@ep-example.region.aws.neon.tech/neondb?sslmode=require&connect_timeout=15"

# Auth — OBRIGATÓRIO. Gere com: openssl rand -base64 32
# A aplicação não inicia sem esta variável definida.
JWT_SECRET="gere-um-segredo-forte-aqui"

# App
NODE_ENV="development"

# Upload
# Tamanho máximo de arquivo em bytes (padrão: 10 MB).
MAX_FILE_SIZE=10485760

# Dados da Representada — usados como padrão na geração de contratos
REPRESENTADA_RAZAO_SOCIAL="FÓRMULA DISTRIBUIDORA DE ALIMENTOS LTDA"
REPRESENTADA_CNPJ="13.555.022/0001-60"
REPRESENTADA_ENDERECO="Rua São José, 69, Jardim América"
REPRESENTADA_CIDADE="Várzea Grande"
REPRESENTADA_UF="MT"
REPRESENTADA_CEP="78110-800"
REPRESENTADA_REPRESENTANTE_LEGAL="HELBERTY KOWALSKI GONÇALVES"
REPRESENTADA_REPRESENTANTE_CPF="013.808.871-35"
REPRESENTADA_REPRESENTANTE_RG="13665359/SSP-MT"

# Vercel Blob — armazenamento de documentos (recomendado em produção)
# Crie um Blob Store em: vercel.com/dashboard → Storage → Create → Blob
# Sem essa variável, os arquivos são gravados no banco (modo fallback, não recomendado).
BLOB_READ_WRITE_TOKEN=""
